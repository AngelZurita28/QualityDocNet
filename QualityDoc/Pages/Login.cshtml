@page
@model LoginModel

<h2>Login</h2>

<form method="post">
    <div>
        <label>Correo:</label>
        <input type="email" asp-for="Correo" required />
    </div>

    <div>
        <label>Contraseña:</label>
        <input type="password" asp-for="Password" required />
    </div>

    <button type="submit">Iniciar sesión</button>
</form>

<p style="color:red">@Model.Error</p>