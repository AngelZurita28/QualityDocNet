<!DOCTYPE html>
<html lang="es">
@inject QualityDoc.Data.AppDbContext DbContext
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QualityDoc</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    <style>
        body { font-family: 'Inter', sans-serif; }
        .sidebar-active { background-color: #ebf8ff; color: #2b6cb0; font-weight: 600; border-left: 4px solid #3182ce; }
    </style>
</head>

<body class="bg-gray-100">

    <div class="flex h-screen overflow-hidden">

        <!-- Sidebar -->
        <aside class="w-64 bg-white shadow-xl flex flex-col z-20">
            <div class="p-6 border-b">
                <h1 class="text-2xl font-bold text-blue-600 flex items-center gap-2">
                    <span class="material-symbols-outlined">description</span>
                    QualityDoc
                </h1>
            </div>

            <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
                
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 px-2">Menú Principal</p>

                @{
                    var rolUsuarioNav = ViewContext.HttpContext.Session.GetString("Rol") ?? "";
                    var userIdVal = ViewContext.HttpContext.Session.GetInt32("UserId");
                    
                    bool showAdmin = rolUsuarioNav.Equals("Admin", StringComparison.OrdinalIgnoreCase) || 
                                     rolUsuarioNav.Equals("Administrador", StringComparison.OrdinalIgnoreCase) || 
                                     rolUsuarioNav.Equals("SuperAdmin", StringComparison.OrdinalIgnoreCase) || 
                                     rolUsuarioNav.Equals("Súperadmin", StringComparison.OrdinalIgnoreCase) || 
                                     rolUsuarioNav.Equals("Super Admin", StringComparison.OrdinalIgnoreCase);

                    int pendingApprovals = 0;
                    int rejectedDocs = 0;

                    if (userIdVal.HasValue)
                    {
                        var currentUser = DbContext.Users.Find(userIdVal.Value);
                        if (currentUser != null)
                        {
                            rejectedDocs = DbContext.Documents.Count(d => d.AuthorId == currentUser.Id && d.StatusId == 4 && d.IsLatest);

                            if (showAdmin)
                            {
                                bool isSuper = rolUsuarioNav.Contains("Super", StringComparison.OrdinalIgnoreCase);
                                if (isSuper) {
                                    pendingApprovals = DbContext.Documents.Count(d => d.StatusId == 2 && d.IsLatest);
                                } else {
                                    pendingApprovals = DbContext.Documents.Count(d => d.StatusId == 2 && d.CompanyId == currentUser.CompanyId && d.IsLatest && d.AuthorId != currentUser.Id);
                                }
                            }
                        }
                    }
                }

                <a asp-page="/Index"
                   class="flex items-center justify-between p-3 rounded-lg transition hover:bg-gray-50 text-gray-600 @(Context.Request.Path == "/Index" || Context.Request.Path == "/" ? "sidebar-active" : "")">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined">dashboard</span>
                        Dashboard
                    </div>
                    @if (pendingApprovals > 0)
                    {
                        <span class="bg-yellow-100 text-yellow-800 text-[10px] font-bold px-2 py-0.5 rounded-full shadow-sm animate-pulse">
                            @pendingApprovals
                        </span>
                    }
                </a>

                <a asp-page="/Documents/List"
                   class="flex items-center justify-between p-3 rounded-lg transition hover:bg-gray-50 text-gray-600 @(Context.Request.Path.StartsWithSegments("/Documents/List") ? "sidebar-active" : "")">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined">folder_open</span>
                        Mis Documentos
                    </div>
                    @if (rejectedDocs > 0)
                    {
                        <span class="bg-red-100 text-red-800 text-[10px] font-bold px-2 py-0.5 rounded-full shadow-sm animate-bounce">
                            @rejectedDocs
                        </span>
                    }
                </a>

                @if (showAdmin)
                {
                    <a asp-page="/Admin/Users"
                       class="flex items-center gap-3 p-3 rounded-lg transition hover:bg-gray-50 text-gray-600 @(Context.Request.Path.StartsWithSegments("/Admin/Users") ? "sidebar-active" : "")">
                        <span class="material-symbols-outlined">manage_accounts</span>
                        Gestión de Usuarios
                    </a>
                }

                <div class="pt-4 mt-4 border-t">
                    <button onclick="openModal()"
                            class="w-full flex items-center justify-center gap-2 bg-blue-600 text-white p-3 rounded-xl shadow-md hover:bg-blue-700 transition">
                        <span class="material-symbols-outlined">add_circle</span>
                        Nuevo Documento
                    </button>
                </div>
            </nav>

            <!-- Bottom Sidebar -->
            <div class="p-4 border-t bg-gray-50">
                @{
                    var nombreUsuario = ViewContext.HttpContext.Session.GetString("Usuario");
                    var rolUsuario = ViewContext.HttpContext.Session.GetString("Rol");
                    var empresaUsuario = ViewContext.HttpContext.Session.GetString("Empresa");
                    var departamentoUsuario = ViewContext.HttpContext.Session.GetString("Departamento");
                }
                @if (!string.IsNullOrEmpty(nombreUsuario))
                {
                    <div class="flex items-center gap-3 px-3 py-2 mb-2">
                        <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white text-xs font-bold">
                            @(nombreUsuario.Length > 0 ? nombreUsuario[0].ToString().ToUpper() : "?")
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-xs font-semibold text-gray-700 truncate">@nombreUsuario</p>
                            <p class="text-[10px] text-blue-600 font-medium truncate">@empresaUsuario | @departamentoUsuario</p>
                            <p class="text-[10px] text-gray-400 truncate">@rolUsuario</p>
                        </div>
                    </div>
                }
                <a href="/Logout" 
                   class="flex items-center gap-3 p-3 rounded-lg text-red-600 hover:bg-red-50 transition w-full">
                    <span class="material-symbols-outlined">logout</span>
                    Cerrar Sesión
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto p-8 relative">
            @RenderBody()
        </main>

    </div>

    <!-- MODAL GLOBAL DE CREACIÓN (Disponible en todas las páginas) -->
    <div id="modalCreate"
         class="fixed inset-0 bg-black/50 hidden items-center justify-center z-[100] backdrop-blur-sm">

        <div class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
            
            <div class="p-6 border-b flex justify-between items-center bg-gray-50">
                <h2 class="text-xl font-bold text-gray-800 flex items-center gap-2">
                    <span class="material-symbols-outlined text-blue-600">upload_file</span>
                    Subir Nuevo Documento
                </h2>
                <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form id="formCreateDocGlobal" method="post" enctype="multipart/form-data" action="/Index?handler=Create" class="p-8 space-y-5">
                @Html.AntiForgeryToken()
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Título</label>
                            <input name="Title" class="w-full border-2 border-gray-100 rounded-xl px-4 py-2 focus:border-blue-400 outline-none transition" required placeholder="Nombre del archivo" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Departamento</label>
                            <select name="SelectedDepartmentId" class="w-full border-2 border-gray-100 rounded-xl px-4 py-2 focus:border-blue-400 outline-none transition" required>
                                <option value="">Selecciona un área...</option>
                                @foreach (var dept in DbContext.Departments.OrderBy(d => d.Name))
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Descripción</label>
                            <textarea name="Description" rows="2" class="w-full border-2 border-gray-100 rounded-xl px-4 py-2 focus:border-blue-400 outline-none transition" placeholder="Detalles adicionales..."></textarea>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="border-2 border-dashed border-gray-200 rounded-2xl p-6 text-center hover:border-blue-300 transition cursor-pointer relative bg-gray-50">
                            <input name="UploadFile" type="file" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" required onchange="updateFileName(this)" />
                            <span class="material-symbols-outlined text-4xl text-gray-300 mb-2">cloud_upload</span>
                            <p id="fileNameDisplay" class="text-xs text-gray-500">Haz clic o arrastra el archivo aquí</p>
                        </div>

                        <div class="bg-blue-50 p-4 rounded-xl border border-blue-100">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input id="chkNuevaVersion" name="EsNuevaVersion" type="checkbox" value="true" class="w-4 h-4 rounded text-blue-600" onchange="toggleVersionField()" />
                                <span class="text-sm font-semibold text-blue-800">¿Es una nueva versión?</span>
                            </label>
                            <div id="versionCodeBlock" class="hidden mt-3 space-y-2">
                                <input id="inputCodigoExistente" name="CodigoExistente" class="w-full border border-blue-200 rounded-lg px-3 py-1.5 text-xs outline-none focus:ring-2 focus:ring-blue-400" placeholder="Código: DOC-XXXXXXXX" />
                                <div id="versionBadge" class="hidden items-center gap-1.5 text-xs text-blue-700 bg-blue-100 rounded-lg px-3 py-1.5">
                                    <span class="material-symbols-outlined text-[14px]">auto_awesome</span>
                                    <span>Número de versión detectado automáticamente</span>
                                    <span id="versionNumLabel" class="font-bold ml-1"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="errorMsgGlobal" class="hidden p-3 bg-red-50 text-red-600 rounded-xl text-xs font-medium border border-red-100"></div>

                <div class="flex justify-end gap-3 pt-6 border-t">
                    <button type="button" onclick="closeModal()" class="px-6 py-2.5 rounded-xl border font-semibold text-gray-600 hover:bg-gray-50 transition">
                        Cancelar
                    </button>
                    <button type="submit" id="btnSaveGlobal" class="px-8 py-2.5 bg-blue-600 text-white rounded-xl font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 transition">
                        Guardar Documento
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModal() {
            const modal = document.getElementById("modalCreate");
            modal.classList.remove("hidden");
            modal.classList.add("flex");
            document.getElementById("errorMsgGlobal").classList.add("hidden");
            document.getElementById("fileNameDisplay").innerText = "Haz clic o arrastra el archivo aquí";
            // Reset version fields
            document.getElementById("chkNuevaVersion").checked = false;
            document.getElementById("versionCodeBlock").classList.add("hidden");
            document.getElementById("versionBadge").classList.add("hidden");
            document.getElementById("versionBadge").classList.remove("flex");
            document.getElementById("inputCodigoExistente").value = "";
        }

        function toggleVersionField() {
            const checked = document.getElementById("chkNuevaVersion").checked;
            const block = document.getElementById("versionCodeBlock");
            if (checked) {
                block.classList.remove("hidden");
            } else {
                block.classList.add("hidden");
                document.getElementById("versionBadge").classList.add("hidden");
                document.getElementById("versionBadge").classList.remove("flex");
                document.getElementById("inputCodigoExistente").value = "";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            const codigoInput = document.getElementById("inputCodigoExistente");
            if (codigoInput) {
                codigoInput.addEventListener("blur", async function () {
                    const codigo = this.value.trim();
                    const badge = document.getElementById("versionBadge");
                    const label = document.getElementById("versionNumLabel");
                    if (!codigo) { badge.classList.add("hidden"); badge.classList.remove("flex"); return; }
                    try {
                        const r = await fetch(`/api/documents/version?code=${encodeURIComponent(codigo)}`);
                        if (r.ok) {
                            const data = await r.json();
                            label.textContent = `v${data.nextVersion}`;
                            badge.classList.remove("hidden");
                            badge.classList.add("flex");
                        } else {
                            badge.classList.add("hidden"); badge.classList.remove("flex");
                        }
                    } catch { badge.classList.add("hidden"); badge.classList.remove("flex"); }
                });
            }
        });

        function closeModal() {
            const modal = document.getElementById("modalCreate");
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        }

        function updateFileName(input) {
            const display = document.getElementById("fileNameDisplay");
            if (input.files && input.files.length > 0) {
                display.innerHTML = `<span class="font-bold text-blue-600">${input.files[0].name}</span>`;
            } else {
                display.innerText = "Haz clic o arrastra el archivo aquí";
            }
        }

        document.getElementById("formCreateDocGlobal").onsubmit = async function(e) {
            e.preventDefault();
            const btn = document.getElementById("btnSaveGlobal");
            const errorDiv = document.getElementById("errorMsgGlobal");
            
            btn.disabled = true;
            btn.innerHTML = '<span class="flex items-center gap-2">Subiendo...</span>';
            errorDiv.classList.add("hidden");

            const formData = new FormData(this);

            try {
                const response = await fetch(this.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    window.location.reload();
                } else {
                    errorDiv.innerText = "Error al subir: Verifica los datos y tu conexión.";
                    errorDiv.classList.remove("hidden");
                }
            } catch (err) {
                errorDiv.innerText = "Error de conexión con el servidor.";
                errorDiv.classList.remove("hidden");
            } finally {
                btn.disabled = false;
                btn.innerText = "Guardar Documento";
            }
        };
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>