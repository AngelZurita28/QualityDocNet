<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QualityDoc</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <style>
        body {
        font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-100">

    <div class="flex">

        <aside class="w-64 bg-white h-screen shadow-md p-4 fixed">
            <h1 class="text-xl font-bold text-blue-600">QualityDoc</h1>

            <nav class="mt-6 space-y-2">

                <a asp-page="/Index"
                       class="block p-2 rounded hover:bg-gray-200
                    @(Context.Request.Path == "/Index" ? "bg-blue-100 text-blue-700" : "")">
                    Dashboard
                </a>

                <a asp-page="/Documents/List"
                       class="block p-2 rounded hover:bg-gray-200
                    @(Context.Request.Path.StartsWithSegments("/Documents/List") ? "bg-blue-100 text-blue-700" : "")">
                    Mis Documentos
                </a>
            </nav>
        </aside>

        <main class="flex-1 ml-64 p-6">
            @RenderBody()
        </main>

    </div>

</body>
</html>