@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="p-6 max-w-7xl mx-auto space-y-6 text-sm">

    @{
        var nombreUsuarioDash = ViewContext.HttpContext.Session.GetString("Usuario");
    }
    @if (!string.IsNullOrEmpty(nombreUsuarioDash))
    {
        <div class="bg-gradient-to-r from-blue-600 to-blue-500 text-white rounded-xl px-5 py-4 flex items-center gap-3 shadow-md">
            <span class="material-symbols-outlined text-white text-2xl">waving_hand</span>
            <div>
                <p class="text-xs opacity-80">Bienvenido de vuelta</p>
                <p class="font-bold text-lg leading-tight">@nombreUsuarioDash</p>
            </div>
        </div>
    }

    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-xl font-semibold">DASHBOARD</h2>
            <p class="text-gray-500 text-xs">Administra, sincroniza y aprueba documentos</p>
        </div>

        <button onclick="openModal()"
                class="bg-blue-600 text-white px-4 py-2 rounded-lg text-xs flex items-center gap-2 hover:bg-blue-700">
            <span class="material-symbols-outlined text-[16px]">add</span>
            Nuevo Documento
        </button>
    </div>

    <form method="get" class="bg-white p-3 rounded-lg border flex items-center gap-3 w-full max-w-lg">
        <span class="material-symbols-outlined text-gray-400 text-[18px]">search</span>
        <input type="text"
               asp-for="SearchTerm"
               placeholder="Buscar por código, título o descripción..."
               class="w-full text-sm outline-none" />
        @if (!string.IsNullOrEmpty(Model.SearchTerm))
        {
            <a asp-page="./Index" class="text-gray-400 hover:text-red-500 transition">
                <span class="material-symbols-outlined text-[16px]">close</span>
            </a>
        }
        <button type="submit" class="hidden">Buscar</button>
    </form>

    <div class="bg-white rounded-lg border overflow-hidden">

        <table class="w-full text-sm">

            <thead class="bg-gray-50 text-xs text-gray-500">
                <tr>
                    <th class="p-3 text-left">Código</th>
                    <th class="p-3 text-left">Versión</th>
                    <th class="p-3 text-left">Estado</th>
                    <th class="p-3 text-left">Sync</th>
                    <th class="p-3 text-left">Autor</th>
                    <th class="p-3 text-left">Descripción</th>
                    <th class="p-3 text-right">Acción</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var doc in Model.Documentos)
                {
                    <tr class="border-t hover:bg-gray-50">

                        <td class="p-3 font-medium">@doc.DocumentCode</td>
                        <td class="p-3">v@(doc.VersionNumber)</td>

                        <td class="p-3">
                            @{
                                string badgeClass = doc.StatusId switch {
                                    1 => "bg-gray-100 text-gray-800",
                                    2 => "bg-yellow-100 text-yellow-800",
                                    3 => "bg-green-100 text-green-800",
                                    4 => "bg-red-100 text-red-800",
                                    _ => "bg-gray-100 text-gray-800"
                                };
                                string statusName = doc.Status?.Name ?? doc.StatusId switch {
                                    1 => "Borrador",
                                    2 => "En Revisión",
                                    3 => "Aprobado",
                                    4 => "Rechazado",
                                    _ => "Desconocido"
                                };
                            }
                            <span class="px-2 py-1 rounded text-[10px] uppercase tracking-wider font-bold @badgeClass">
                                @statusName
                            </span>
                        </td>

                        <td class="p-3">
                            @if (doc.SyncFirebase)
                            {
                                <span class="text-green-600 text-xs">✔ Firebase</span>
                            }
                            else
                            {
                                <span class="text-red-600 text-xs">❌ Firebase</span>
                            }
                        </td>

                        <td class="p-3 text-gray-500">@(doc.Author?.FullName ?? "Desconocido")</td>

                        <td class="p-3 text-gray-500 max-w-[250px] truncate">@doc.Description</td>

                        <td class="p-3 text-right space-x-2">

                            @if (doc.StatusId == 3)
                            {
                                @if (!doc.SyncFirebase)
                                {
                                    <form method="post" asp-page-handler="Sync" class="inline">
                                        <input type="hidden" name="id" value="@doc.Id" />
                                        <button class="bg-blue-600 text-white px-3 py-1 rounded text-xs hover:bg-blue-700">
                                            Firebase
                                        </button>
                                    </form>
                                }

                                @if (!doc.SyncPostgre)
                                {
                                    <button class="bg-purple-600 text-white px-3 py-1 rounded text-xs hover:bg-purple-700">
                                        Postgre
                                    </button>
                                }
                            }
                            else
                            {
                                <span class="text-xs text-gray-400 italic">No sincronizable</span>
                            }
                        </td>
                    </tr>
                }

            </tbody>

        </table>

        <!-- Paginación -->
        <div class="p-3 flex justify-between items-center text-xs border-t bg-gray-50">
            <span class="text-gray-500">Mostrando página @Model.PageNumber de @(Model.TotalPages == 0 ? 1 : Model.TotalPages)</span>
            
            <div class="flex gap-1">
                <a asp-page="./Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-SearchTerm="@Model.SearchTerm"
                   class="px-2 py-1 border rounded bg-white @(Model.PageNumber <= 1 ? "opacity-50 pointer-events-none" : "hover:bg-gray-100")">
                    ◀
                </a>

                @for (int i = 1; i <= (Model.TotalPages == 0 ? 1 : Model.TotalPages); i++)
                {
                    <a asp-page="./Index" asp-route-pageNumber="@i" asp-route-SearchTerm="@Model.SearchTerm"
                       class="px-2 py-1 border rounded @(i == Model.PageNumber ? "bg-blue-600 text-white" : "bg-white hover:bg-gray-100")">
                        @i
                    </a>
                }

                <a asp-page="./Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-SearchTerm="@Model.SearchTerm"
                   class="px-2 py-1 border rounded bg-white @(Model.PageNumber >= Model.TotalPages ? "opacity-50 pointer-events-none" : "hover:bg-gray-100")">
                    ▶
                </a>
            </div>
        </div>

    </div>

</div>
