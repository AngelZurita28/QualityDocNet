@page
@model IndexModel

@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <div class="flex">

        <aside class="w-64 bg-white h-screen shadow-md p-4">
            <h1 class="text-xl font-bold text-blue-600">QualityDoc</h1>

            <nav class="mt-6 space-y-2">
                <a href="/Index" class="block p-2 bg-blue-100 text-blue-700 rounded">Dashboard</a>
                <a href="/Documents/List" class="block p-2 hover:bg-gray-200 rounded">Documentos</a>
            </nav>

            <div class="mt-10">
                <button onclick="abrirModal()"
                        class="bg-blue-600 text-white px-4 py-2 rounded w-full">
                    + Nuevo Documento
                </button>
            </div>
        </aside>

        <main class="flex-1 p-6">

            <h2 class="text-2xl font-bold mb-2">Gestión de Documentos</h2>
            <p class="text-gray-500 mb-4">Empresa: @ViewData["Empresa"]</p>

            <div class="bg-white rounded shadow">
                <table class="w-full">
                    <thead class="bg-gray-200">
                        <tr>
                            <th class="p-3 text-left">Título</th>
                            <th class="p-3">Versión</th>
                            <th class="p-3">Estado</th>
                            <th class="p-3">Sync</th>
                            <th class="p-3">Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var doc in Model.Documentos)
                        {
                            <tr class="border-t">
                                <td class="p-3">
                                    <b>@doc.Title</b><br />
                                    <span class="text-gray-500 text-sm">@doc.Description</span>
                                </td>

                                <td class="p-3 text-center">
                                    v@doc.VersionNumber
                                </td>

                                <td class="p-3 text-center">
                                    @doc.StatusId
                                </td>

                                <td class="p-3 text-center">
                                    @(doc.SyncFirebase ? "✔" : "❌")
                                </td>

                                <td class="p-3 text-center">
                                    @if (!doc.SyncFirebase)
                                    {
                                        <form method="post" asp-page-handler="Sync">
                                            <input type="hidden" name="id" value="@doc.Id" />
                                            <button class="bg-green-500 text-white px-2 py-1 rounded">
                                                Sync
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </main>

    </div>

    <div id="modalCreate" class="fixed inset-0 bg-black/40 hidden items-center justify-center z-50">

        <div class="bg-white w-full max-w-2xl rounded-xl p-6">

            <h2 class="text-xl font-bold mb-4">Subir Documento</h2>

            <form method="post" enctype="multipart/form-data" asp-page-handler="Create">

                <div class="mb-3">
                    <label>Título</label>
                    <input asp-for="Title" class="w-full border p-2 rounded" required />
                </div>

                <div class="mb-3">
                    <label>Descripción</label>
                    <textarea asp-for="Description" class="w-full border p-2 rounded"></textarea>
                </div>

                <div class="mb-3">
                    <label>Archivo</label>
                    <input type="file" asp-for="File" class="w-full border p-2 rounded" required />
                </div>

                <label>
                    <input type="checkbox" asp-for="EsNuevaVersion" />
                    Es nueva versión
                </label>

                <div class="mt-2">
                    <input asp-for="CodigoExistente" class="w-full border p-2 rounded" placeholder="Código existente" />
                </div>

                <div class="flex justify-end gap-2 mt-4">
                    <button type="button" onclick="cerrarModal()" class="px-4 py-2 border rounded">
                        Cancelar
                    </button>

                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">
                        Guardar
                    </button>
                </div>

            </form>

        </div>

    </div>
    <script>
        function abrirModal() {
        document.getElementById("modalCreate").classList.remove("hidden");
        document.getElementById("modalCreate").classList.add("flex");
        }

        function cerrarModal() {
        document.getElementById("modalCreate").classList.add("hidden");
        }
    </script>

</body>
</html>