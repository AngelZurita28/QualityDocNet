@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="p-6 max-w-7xl mx-auto space-y-6 text-sm">

    @{
        var nombreUsuarioDash = ViewContext.HttpContext.Session.GetString("Usuario");
    }
    @if (!string.IsNullOrEmpty(nombreUsuarioDash))
    {
        <div class="bg-gradient-to-r from-blue-600 to-blue-500 text-white rounded-xl px-5 py-4 flex items-center gap-3 shadow-md">
            <span class="material-symbols-outlined text-white text-2xl">waving_hand</span>
            <div>
                <p class="text-xs opacity-80">Bienvenido de vuelta</p>
                <p class="font-bold text-lg leading-tight">@nombreUsuarioDash</p>
            </div>
        </div>
    }

    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-xl font-semibold">DASHBOARD</h2>
            <p class="text-gray-500 text-xs">Administra, sincroniza y aprueba documentos</p>
        </div>

        @if (Model.CanCreateDraft)
        {
            <button onclick="openModal()"
                    class="bg-blue-600 text-white px-4 py-2 rounded-lg text-xs flex items-center gap-2 hover:bg-blue-700 transition shadow-lg shadow-blue-100">
                <span class="material-symbols-outlined text-[16px]">add</span>
                Nuevo Documento
            </button>
        }
    </div>

    <!-- Tarjetas Resumen -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
        <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition">
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">description</span>
            </div>
            <div>
                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Total Documentos</p>
                <p class="text-2xl font-black text-gray-800">@Model.CountTotal</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition">
            <div class="w-12 h-12 bg-yellow-50 text-yellow-600 rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">pending_actions</span>
            </div>
            <div>
                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">En Revisión</p>
                <p class="text-2xl font-black text-gray-800">@Model.CountRevision</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition">
            <div class="w-12 h-12 bg-green-50 text-green-600 rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">check_circle</span>
            </div>
            <div>
                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Activos</p>
                <p class="text-2xl font-black text-gray-800">@Model.CountActivo</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-4 hover:shadow-md transition">
            <div class="w-12 h-12 bg-red-50 text-red-600 rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">error</span>
            </div>
            <div>
                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Rechazados</p>
                <p class="text-2xl font-black text-gray-800">@Model.CountRechazado</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        <!-- Gráfica de Pastel (Estados) -->
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex flex-col items-center">
            <h3 class="font-bold text-gray-700 mb-6 uppercase tracking-widest text-[10px]">Distribución por Estado</h3>
            <div class="w-full max-w-[280px]">
                <canvas id="statusChart"></canvas>
            </div>
        </div>

        <!-- Gráfica de Barras (Departamentos) -->
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex flex-col">
            <h3 class="font-bold text-gray-700 mb-6 uppercase tracking-widest text-[10px]">Carga por Departamento</h3>
            <div class="flex-1 min-h-[300px]">
                <canvas id="deptChart"></canvas>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from C# Model
        const deptLabels = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Name)));
        const borradorData = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Borrador)));
        const revisionData = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Revision)));
        const candidataData = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Candidata)));
        const rechazadoData = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Rechazado)));
        const activoData = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Activo)));
        const obsoletoData = @Html.Raw(Json.Serialize(Model.DeptStats.Select(s => s.Obsoleto)));

        // Status Chart (Pie)
        const ctxStatus = document.getElementById('statusChart').getContext('2d');
        new Chart(ctxStatus, {
            type: 'pie',
            data: {
                labels: ['Borrador', 'En Revisión', 'Candidata', 'Rechazado', 'Activo', 'Obsoleto'],
                datasets: [{
                    data: [@Model.CountBorrador, @Model.CountRevision, @Model.CountCandidata, @Model.CountRechazado, @Model.CountActivo, @Model.CountObsoleto],
                    backgroundColor: ['#e2e8f0', '#fef08a', '#bfdbfe', '#fecaca', '#bbf7d0', '#e5e7eb'],
                    borderColor: ['#94a3b8', '#facc15', '#60a5fa', '#f87171', '#4ade80', '#9ca3af'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 10 } } }
                }
            }
        });

        // Dept Chart (Stacked Bar)
        const ctxDept = document.getElementById('deptChart').getContext('2d');
        new Chart(ctxDept, {
            type: 'bar',
            data: {
                labels: deptLabels,
                datasets: [
                    { label: 'Borrador', data: borradorData, backgroundColor: '#e2e8f0' },
                    { label: 'Revisión', data: revisionData, backgroundColor: '#fef08a' },
                    { label: 'Candidata', data: candidataData, backgroundColor: '#bfdbfe' },
                    { label: 'Rechazado', data: rechazadoData, backgroundColor: '#fecaca' },
                    { label: 'Activo', data: activoData, backgroundColor: '#bbf7d0' },
                    { label: 'Obsoleto', data: obsoletoData, backgroundColor: '#e5e7eb' }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { stacked: true, grid: { display: false }, ticks: { font: { size: 10 } } },
                    y: { stacked: true, beginAtZero: true, ticks: { font: { size: 10 } } }
                },
                plugins: {
                    legend: { position: 'top', labels: { boxWidth: 12, font: { size: 10 } } }
                }
            }
        });
    </script>
}
