@page
@model QualityDoc.Pages.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QualityDoc - Registro de Usuario</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <style>
        body { background-color: #F9FAFB; font-family: 'Inter', sans-serif; }
    </style>
</head>

<body class="flex flex-col min-h-screen">

    <main class="flex-grow flex items-center justify-center p-6">

        <div class="w-full max-w-[500px]">

            <div class="flex flex-col items-center mb-8">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-blue-600 text-4xl">person_add</span>
                    <h1 class="text-2xl font-bold">Crear Cuenta</h1>
                </div>
                <p class="text-gray-500 text-sm">Únete a QualityDoc Document System</p>
            </div>

            <div class="bg-white border rounded-2xl p-8 shadow-xl">

                <form method="post" class="space-y-5">
                    @Html.AntiForgeryToken()

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl flex items-center gap-2 text-sm font-medium mb-4">
                            <span class="material-symbols-outlined text-[18px]">check_circle</span>
                            @Model.SuccessMessage
                        </div>
                    }

                    <div class="grid grid-cols-1 gap-5">
                        
                        <div>
                            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1 block">Nombre Completo</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-2.5 text-gray-400 text-sm">person</span>
                                <input asp-for="FullName" class="w-full pl-10 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 text-sm py-2" placeholder="Juan Pérez" required />
                            </div>
                        </div>

                        <div>
                            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1 block">Correo Electrónico</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-2.5 text-gray-400 text-sm">mail</span>
                                <input asp-for="Email" type="email" class="w-full pl-10 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 text-sm py-2" placeholder="juan@empresa.com" required />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1 block">Empresa</label>
                                <select asp-for="CompanyId" asp-items="Model.Empresas" class="w-full border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 text-sm py-2 bg-white" required>
                                    <option value="">Seleccionar...</option>
                                </select>
                            </div>

                            <div>
                                <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1 block">Rol de Usuario</label>
                                <select asp-for="RoleId" class="w-full border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 text-sm py-2 bg-white" required>
                                    <option value="1">Super Admin</option>
                                    <option value="2">Admin</option>
                                    <option value="3">Reviewer</option>
                                    <option value="4">Redacter</option>
                                    <option value="5">Operador</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1 block">Departamento</label>
                            <select asp-for="DepartmentId" asp-items="Model.Departamentos" class="w-full border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 text-sm py-2 bg-white" required>
                                <option value="">Seleccionar Departamento...</option>
                            </select>
                        </div>

                        <div>
                            <label class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1 block">Contraseña</label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-2.5 text-gray-400 text-sm">lock</span>
                                <input asp-for="Password" type="password" class="w-full pl-10 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 text-sm py-2" placeholder="••••••••" required />
                            </div>
                        </div>

                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition shadow-lg shadow-blue-200 flex items-center justify-center gap-2">
                            Finalizar Registro
                            <span class="material-symbols-outlined text-sm">how_to_reg</span>
                        </button>
                    </div>

                </form>

                @if (!string.IsNullOrEmpty(Model.Error))
                {
                    <div class="mt-4 p-3 bg-red-50 text-red-600 rounded-xl text-xs text-center font-semibold">
                        @Model.Error
                    </div>
                }

                <div class="mt-6 pt-6 border-t text-center">
                    <p class="text-xs text-gray-500 mb-2">¿Ya tienes una cuenta?</p>
                    <a href="/Login" class="text-blue-600 font-bold hover:underline transition">
                        Volver al inicio de sesión
                    </a>
                </div>

            </div>

            <p class="mt-8 text-center text-gray-400 text-xs tracking-widest uppercase">
                QualityDoc Document System
            </p>

        </div>
    </main>

</body>
</html>