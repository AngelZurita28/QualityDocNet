@page
@model QualityDoc.Pages.RegisterModel

<h2>Registro</h2>

<form method="post">
    <div>
        <label>Nombre:</label>
        <input type="text" asp-for="FullName" required />
    </div>

    <div>
        <label>Correo:</label>
        <input type="email" asp-for="Email" required />
    </div>

    <div>
        <label>Contraseña:</label>
        <input type="password" asp-for="Password" required />
    </div>

    <div>
        <label>Rol:</label>
        <select asp-for="RoleId">
            <option value="1">SuperAdmin</option>
            <option value="2">Admin</option>
            <option value="3">Approver</option>
            <option value="4">Operator</option>
        </select>
    </div>

    <button type="submit">Registrarse</button>
</form>

<p style="color:red">@Model.Error</p>
<p style="color:green">@Model.Mensaje</p>