@page
@model QualityDoc.Pages.Documents.ApprovalModel
@{
    ViewData["Title"] = "Aprobaciones";
    var diffInsertedCount = Model.DiffLines?.Count(line => line.Type == DiffPlex.DiffBuilder.Model.ChangeType.Inserted) ?? 0;
    var diffDeletedCount = Model.DiffLines?.Count(line => line.Type == DiffPlex.DiffBuilder.Model.ChangeType.Deleted) ?? 0;
    var diffUnchangedCount = Model.DiffLines?.Count(line => line.Type == DiffPlex.DiffBuilder.Model.ChangeType.Unchanged) ?? 0;
    var diffChangeCount = diffInsertedCount + diffDeletedCount;
}

<div class="p-6 max-w-7xl mx-auto grid grid-cols-1 xl:grid-cols-5 gap-6">

    <!-- Columna Izquierda: Vista del Documento -->
    <div class="xl:col-span-3 bg-gray-50 border rounded-xl overflow-hidden shadow-sm h-[750px] flex flex-col relative">
        @if (Model.Documento != null && !string.IsNullOrEmpty(Model.Documento.FilePath))
        {
            var ext = System.IO.Path.GetExtension(Model.Documento.FilePath).ToLower();
            var isPdf = ext == ".pdf";
            var isImage = ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".gif" || ext == ".webp";
            var isOffice = ext == ".doc" || ext == ".docx" || ext == ".xls" || ext == ".xlsx" || ext == ".ppt" || ext == ".pptx";
            
            <div class="bg-white p-3 border-b flex justify-between items-center shadow-sm z-10">
                <div class="flex items-center gap-2 overflow-hidden">
                    <span class="material-symbols-outlined text-blue-500 text-[20px]">description</span>
                    <span class="text-xs font-bold text-gray-700 truncate max-w-[250px]" title="@System.IO.Path.GetFileName(Model.Documento.FilePath)">
                        @System.IO.Path.GetFileName(Model.Documento.FilePath)
                    </span>
                    <span class="bg-gray-100 text-gray-500 px-2 py-0.5 rounded text-[10px] font-mono uppercase border">@ext.Replace(".", "")</span>
                </div>
                <a href="@Model.Documento.FilePath" download class="bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100 px-3 py-1.5 rounded-lg text-xs font-bold transition flex items-center gap-1 flex-shrink-0">
                    <span class="material-symbols-outlined text-[16px]">download</span> Descargar Original
                </a>
            </div>

            @if (Model.DocumentoParent != null)
            {
                <div class="flex border-b border-gray-200 bg-white z-10 flex-shrink-0">
                    <button type="button" onclick="switchTab('preview')" id="tab-preview" aria-controls="container-preview" aria-selected="true" class="flex-1 py-2.5 px-4 text-xs font-bold text-blue-600 border-b-2 border-blue-600 flex items-center justify-center gap-2 transition-all duration-200 hover:bg-blue-50/30">
                        <span class="material-symbols-outlined text-[16px]">visibility</span>
                        Vista Previa
                    </button>
                    <button type="button" onclick="switchTab('diff')" id="tab-diff" aria-controls="container-diff" aria-selected="false" class="flex-1 py-2.5 px-4 text-xs font-bold text-gray-500 border-b-2 border-transparent flex items-center justify-center gap-2 transition-all duration-200 hover:bg-gray-50/50 hover:text-gray-700">
                        <span class="material-symbols-outlined text-[16px]">difference</span>
                        Comparar con v@(QualityDoc.Services.DocumentVersionService.FormatVersion(Model.DocumentoParent.VersionNumber))
                        @if (diffChangeCount > 0)
                        {
                            <span class="rounded-full bg-blue-100 px-2 py-0.5 text-[10px] font-extrabold text-blue-700">@diffChangeCount</span>
                        }
                    </button>
                </div>
            }

            <!-- Vista Previa Container -->
            <div id="container-preview" class="flex-1 bg-gray-200/50 flex items-center justify-center relative w-full h-full overflow-hidden">
                @if (isPdf)
                {
                    <iframe src="@Model.Documento.FilePath#toolbar=0&navpanes=0" class="w-full h-full border-0 shadow-inner"></iframe>
                }
                else if (isImage)
                {
                    <div class="w-full h-full p-6 flex items-center justify-center overflow-auto">
                        <img src="@Model.Documento.FilePath" class="max-w-full max-h-full object-contain shadow-md border rounded bg-white" alt="Vista previa del documento" />
                    </div>
                }
                else if (isOffice)
                {
                    <div class="text-center p-8 bg-white rounded-xl shadow-sm border border-gray-200 max-w-sm m-4">
                        <div class="w-16 h-16 mx-auto mb-4 bg-blue-50 rounded-full flex items-center justify-center text-blue-600">
                            <span class="material-symbols-outlined text-4xl">edit_document</span>
                        </div>
                        <h4 class="text-lg font-bold text-gray-800 mb-2">Documento de Office</h4>
                        <p class="text-sm text-gray-500 mb-6">Para visualizar o editar este archivo de Word/Excel/PowerPoint sin perder formato, debes descargarlo a tu equipo.</p>
                        <a href="@Model.Documento.FilePath" download class="inline-flex items-center justify-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-lg font-medium shadow hover:bg-blue-700 transition w-full">
                            <span class="material-symbols-outlined">download</span>
                            Descargar @ext.ToUpper()
                        </a>
                    </div>
                }
                else
                {
                    <div class="text-center p-8">
                        <span class="material-symbols-outlined text-6xl text-gray-300 mb-3 drop-shadow-sm">unknown_document</span>
                        <h4 class="text-gray-700 font-medium mb-1">Formato de archivo no soportado</h4>
                        <p class="text-sm text-gray-500 mb-4">No podemos mostrar una vista previa de los archivos @ext en el navegador.</p>
                        <a href="@Model.Documento.FilePath" download class="bg-white border shadow-sm text-gray-700 px-5 py-2 rounded-lg hover:bg-gray-50 font-medium text-sm transition inline-flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">download</span>
                            Descargar Archivo
                        </a>
                    </div>
                }
            </div>

            @if (Model.DocumentoParent != null)
            {
                <!-- Comparación Container (Oculto por defecto) -->
                <div id="container-diff" class="w-full h-full hidden flex flex-col bg-slate-50 overflow-hidden" role="tabpanel" aria-labelledby="tab-diff">
                    <div class="diff-toolbar z-10 flex-shrink-0 border-b border-slate-200 bg-white">
                        <div class="flex flex-col gap-4 p-4 lg:flex-row lg:items-center lg:justify-between">
                            <div class="min-w-0">
                                <div class="mb-1 flex items-center gap-2">
                                    <span class="material-symbols-outlined rounded-lg bg-blue-50 p-1 text-[18px] text-blue-600">difference</span>
                                    <p class="text-[10px] font-extrabold uppercase tracking-[0.18em] text-slate-400">Control de diferencias</p>
                                </div>
                                <h3 class="truncate text-sm font-extrabold text-slate-800">
                                    v@(QualityDoc.Services.DocumentVersionService.FormatVersion(Model.DocumentoParent.VersionNumber))
                                    <span class="mx-1 text-slate-300">→</span>
                                    v@(QualityDoc.Services.DocumentVersionService.FormatVersion(Model.Documento.VersionNumber))
                                </h3>
                                <p class="mt-1 text-xs text-slate-500">Revisa solo el texto extraído del documento antes de aprobar o rechazar.</p>
                            </div>

                            <div class="grid grid-cols-3 gap-2 text-center">
                                <div class="rounded-xl border border-emerald-100 bg-emerald-50 px-3 py-2">
                                    <p class="text-base font-black text-emerald-700">@diffInsertedCount</p>
                                    <p class="text-[9px] font-bold uppercase tracking-wider text-emerald-700">Agregadas</p>
                                </div>
                                <div class="rounded-xl border border-rose-100 bg-rose-50 px-3 py-2">
                                    <p class="text-base font-black text-rose-700">@diffDeletedCount</p>
                                    <p class="text-[9px] font-bold uppercase tracking-wider text-rose-700">Eliminadas</p>
                                </div>
                                <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
                                    <p class="text-base font-black text-slate-700">@diffUnchangedCount</p>
                                    <p class="text-[9px] font-bold uppercase tracking-wider text-slate-500">Iguales</p>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50/80 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
                            <div class="flex flex-wrap items-center gap-2 text-[11px] font-bold">
                                <span class="inline-flex items-center gap-1.5 rounded-full bg-white px-2.5 py-1 text-emerald-700 ring-1 ring-emerald-100">
                                    <span class="h-2 w-2 rounded-full bg-emerald-500"></span> Agregado
                                </span>
                                <span class="inline-flex items-center gap-1.5 rounded-full bg-white px-2.5 py-1 text-rose-700 ring-1 ring-rose-100">
                                    <span class="h-2 w-2 rounded-full bg-rose-500"></span> Eliminado
                                </span>
                                <span class="inline-flex items-center gap-1.5 rounded-full bg-white px-2.5 py-1 text-slate-500 ring-1 ring-slate-200">
                                    <span class="h-2 w-2 rounded-full bg-slate-300"></span> Sin cambios
                                </span>
                            </div>

                            <div class="flex flex-wrap items-center gap-2">
                                <button type="button" onclick="scrollToFirstChange()" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-2 text-[11px] font-extrabold text-slate-700 shadow-sm transition hover:border-blue-200 hover:text-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                                    <span class="material-symbols-outlined text-[16px]">south</span>
                                    Primera diferencia
                                </button>
                                <label class="inline-flex cursor-pointer select-none items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 shadow-sm">
                                    <input type="checkbox" id="chkShowOnlyChanges" onchange="toggleUnchangedRows()" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                                    <span class="text-[11px] font-extrabold text-slate-700">Ver solo cambios</span>
                            </label>
                            </div>
                        </div>
                    </div>

                    <div class="diff-scroll flex-1 overflow-auto bg-slate-50 font-mono text-[12px] select-text">
                        @if (Model.DiffLines != null && Model.DiffLines.Any())
                        {
                            <table class="min-w-full border-collapse table-fixed">
                                <thead class="sticky top-0 z-20 border-b border-slate-200 bg-white text-[10px] uppercase tracking-wider text-slate-500 shadow-sm">
                                    <tr>
                                        <th scope="col" class="w-[92px] border-r border-slate-200 px-3 py-2 text-center font-extrabold">Anterior</th>
                                        <th scope="col" class="w-[92px] border-r border-slate-200 px-3 py-2 text-center font-extrabold">Nueva</th>
                                        <th scope="col" class="w-10 px-1 py-2 text-center font-extrabold">Tipo</th>
                                        <th scope="col" class="px-3 py-2 text-left font-extrabold">Contenido</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    @foreach (var line in Model.DiffLines)
                                    {
                                        var isInserted = line.Type == DiffPlex.DiffBuilder.Model.ChangeType.Inserted;
                                        var isDeleted = line.Type == DiffPlex.DiffBuilder.Model.ChangeType.Deleted;
                                        var isUnchanged = line.Type == DiffPlex.DiffBuilder.Model.ChangeType.Unchanged;
                                        
                                        var rowClass = isInserted ? "change-row bg-emerald-50 text-emerald-950 hover:bg-emerald-100/70 border-l-4 border-emerald-500"
                                                     : isDeleted ? "change-row bg-rose-50 text-rose-950 hover:bg-rose-100/70 border-l-4 border-rose-500"
                                                     : "unchanged-row bg-white text-slate-500 hover:bg-slate-100 border-l-4 border-transparent";
                                                     
                                        var sign = isInserted ? "+" : isDeleted ? "-" : " ";
                                        var signClass = isInserted ? "bg-emerald-600 text-white" : isDeleted ? "bg-rose-600 text-white" : "bg-slate-100 text-slate-400";
                                        
                                        <tr class="diff-row transition-colors @rowClass" data-change-row="@(isInserted || isDeleted ? "true" : "false")">
                                            <td class="border-r border-slate-200 px-3 py-1.5 text-center font-mono text-[10px] text-slate-500 whitespace-nowrap">
                                                @if (line.OldPageNumber.HasValue)
                                                {
                                                    <span>P.@line.OldPageNumber L.@line.OldLineNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="opacity-20">-</span>
                                                }
                                            </td>
                                            <td class="border-r border-slate-200 px-3 py-1.5 text-center font-mono text-[10px] text-slate-500 whitespace-nowrap">
                                                @if (line.NewPageNumber.HasValue)
                                                {
                                                    <span>P.@line.NewPageNumber L.@line.NewLineNumber</span>
                                                }
                                                else
                                                {
                                                    <span class="opacity-20">-</span>
                                                }
                                            </td>
                                            <td class="px-1 py-1.5 text-center select-none">
                                                <span class="inline-flex h-5 w-5 items-center justify-center rounded-full font-black @signClass">@sign</span>
                                            </td>
                                            <td class="px-3 py-1.5 whitespace-pre-wrap break-words font-mono leading-relaxed">@line.Content</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else if (!string.IsNullOrEmpty(Model.DiffError))
                        {
                            <div class="m-6 rounded-2xl border border-rose-100 bg-white p-8 text-center text-slate-600 shadow-sm">
                                <span class="material-symbols-outlined mb-2 rounded-full bg-rose-50 p-3 text-4xl text-rose-500">warning</span>
                                <p class="font-extrabold text-slate-800">No se puede mostrar la comparación</p>
                                <p class="mt-2 text-xs text-slate-500">@Model.DiffError</p>
                            </div>
                        }
                        else
                        {
                            <div class="m-6 rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-600 shadow-sm">
                                <span class="material-symbols-outlined mb-2 rounded-full bg-blue-50 p-3 text-4xl text-blue-500">task_alt</span>
                                <p class="font-extrabold text-slate-800">No se encontraron diferencias en el texto</p>
                                <p class="mt-2 text-xs text-slate-500">Ambos documentos tienen el mismo texto extraíble o no son PDFs con texto seleccionable.</p>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="flex-1 flex flex-col items-center justify-center text-gray-400 p-8">
                <span class="material-symbols-outlined text-6xl mb-3 opacity-50">broken_image</span>
                <span class="text-lg font-medium text-gray-500">Archivo no encontrado</span>
                <span class="text-sm mt-1 text-center max-w-xs">El archivo físico no se subió correctamente o fue eliminado del servidor.</span>
            </div>
        }
    </div>

    <!-- Columna Derecha: Información + Acciones (UNIFICADOS) -->
    <div class="xl:col-span-2">
        <div class="bg-white rounded-2xl border shadow-lg overflow-hidden flex flex-col h-fit">
            <!-- Sección de Información -->
            <div class="p-6 border-b border-gray-50">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold mb-1">Título del Documento</p>
                        <h2 class="text-xl font-extrabold text-gray-800 leading-tight">@Model.Documento?.Title</h2>
                    </div>
                    @if (Model.CanEdit)
                    {
                        <button onclick="toggleEditMode()" id="btnToggleEdit" class="flex items-center gap-1 text-blue-600 hover:text-blue-700 font-bold text-xs transition p-1.5 hover:bg-blue-50 rounded-lg">
                            <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                        </button>
                    }
                </div>

                <div id="viewInfo" class="space-y-4">
                    @if (!string.IsNullOrEmpty(Model.Documento?.Description))
                    {
                        <p class="text-sm text-gray-600 leading-relaxed">@Model.Documento.Description</p>
                    }
                    
                    <div class="grid grid-cols-2 gap-3 pt-2">
                        <div class="bg-gray-50 p-3 rounded-xl border border-gray-100">
                            <p class="text-[9px] text-gray-400 uppercase font-bold mb-1">Código</p>
                            <p class="font-mono text-xs font-bold text-gray-700">@Model.Documento?.DocumentCode</p>
                        </div>
                        <div class="bg-gray-50 p-3 rounded-xl border border-gray-100">
                            <p class="text-[9px] text-gray-400 uppercase font-bold mb-1">Versión</p>
                            <span class="text-xs font-extrabold text-blue-700 bg-blue-100 px-2 py-0.5 rounded">
                                @(Model.Documento?.VersionNumber.HasValue == true ? $"v{QualityDoc.Services.DocumentVersionService.FormatVersion(Model.Documento.VersionNumber)}" : "Sin version")
                            </span>
                        </div>
                        <div class="bg-gray-50 p-3 rounded-xl border border-gray-100 col-span-2">
                            <p class="text-[9px] text-gray-400 uppercase font-bold mb-1">Departamento / Área</p>
                            <p class="text-xs font-bold text-gray-700">@(Model.Documento?.Department?.Name ?? "No asignado")</p>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-3 border-t border-dashed mt-4">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-[10px] font-bold shadow-sm">
                                @(Model.Documento?.Author?.FullName?[0].ToString().ToUpper() ?? "?")
                            </div>
                            <div>
                                <p class="text-[10px] text-gray-400 font-bold uppercase leading-none mb-1">Autor</p>
                                <p class="text-xs text-gray-700 font-bold">@Model.Documento?.Author?.FullName</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-[10px] text-gray-400 font-bold uppercase leading-none mb-1">Empresa</p>
                            <p class="text-xs text-gray-600 font-medium">@Model.Documento?.Company?.Name</p>
                        </div>
                    </div>
                </div>

                @if (Model.CanEdit)
                {
                    <form id="editForm" method="post" asp-page-handler="Edit" asp-route-id="@Model.Documento?.Id" enctype="multipart/form-data" class="hidden space-y-4 pt-2">
                        <div>
                            <label class="block text-[10px] text-gray-400 uppercase font-bold mb-1">Editar Título</label>
                            <input asp-for="EditTitle" class="w-full border-2 border-gray-100 rounded-xl px-4 py-2 text-sm focus:border-blue-400 outline-none transition" required />
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-400 uppercase font-bold mb-1">Editar Descripción</label>
                            <textarea asp-for="EditDescription" rows="3" class="w-full border-2 border-gray-100 rounded-xl px-4 py-2 text-sm focus:border-blue-400 outline-none transition"></textarea>
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-400 uppercase font-bold mb-1">Cambiar Departamento</label>
                            <select asp-for="EditDepartmentId" class="w-full border-2 border-gray-100 rounded-xl px-4 py-2 text-sm focus:border-blue-400 outline-none transition" required>
                                <option value="">Selecciona un área...</option>
                                @foreach (var dept in Model.DepartmentsList)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-400 uppercase font-bold mb-1">Reemplazar Archivo (Opcional)</label>
                            <input asp-for="NewFile" type="file" class="w-full text-xs text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition" />
                        </div>
                        <div class="flex gap-2">
                            <button type="submit" class="flex-1 bg-blue-600 text-white py-2.5 rounded-xl text-xs font-bold shadow-lg shadow-blue-100 hover:bg-blue-700 transition">Guardar Cambios</button>
                            <button type="button" onclick="toggleEditMode()" class="px-4 py-2 border-2 border-gray-100 rounded-xl text-xs font-bold text-gray-500 hover:bg-gray-50 transition">Cancelar</button>
                        </div>
                    </form>
                }
            </div>

            <!-- Panel de Acciones (INMEDIATAMENTE ABAJO) -->
            <div class="p-6 bg-gray-50 flex-1">
                <div class="flex items-center gap-2 mb-4">
                    <div class="p-1.5 bg-blue-100 rounded-lg">
                        <span class="material-symbols-outlined text-blue-600 text-[18px]">bolt</span>
                    </div>
                    <h3 class="font-bold text-xs text-gray-700 uppercase tracking-widest">Panel de Control</h3>
                </div>

                @if (Model.Documento != null)
                {
                    <div class="space-y-4">
                        @if (Model.Documento.StatusId == 1)
                        {
                            if (Model.CanSendReview)
                            {
                                <form method="post" asp-page-handler="SendReview">
                                    <input type="hidden" name="id" value="@Model.Documento.Id" />
                                    <button class="group w-full bg-blue-600 text-white py-4 rounded-2xl hover:bg-blue-700 font-bold shadow-xl shadow-blue-100 transition-all flex items-center justify-center gap-3 text-sm">
                                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">send</span> 
                                        Enviar a Revisión
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="p-4 text-center bg-white border-2 border-dashed border-gray-200 rounded-2xl text-gray-400 text-xs font-medium">
                                    <p>El autor debe enviar el documento para revisión.</p>
                                </div>
                            }
                        }
                        else if (Model.Documento.StatusId == 2)
                        {
                            if (Model.CurrentUserId == Model.Documento.AuthorId)
                            {
                                <div class="p-4 text-center bg-yellow-50 text-yellow-700 rounded-2xl text-xs font-bold border border-yellow-200 flex flex-col gap-1">
                                    <span class="material-symbols-outlined text-xl">hourglass_empty</span>
                                    Documento en Revisión
                                </div>
                            }
                            else if (Model.CanReviewerApprove)
                            {
                                <div class="grid grid-cols-2 gap-3">
                                    <form method="post" asp-page-handler="Approve">
                                        <input type="hidden" name="id" value="@Model.Documento.Id" />
                                        <button class="w-full bg-green-600 text-white py-4 rounded-2xl hover:bg-green-700 font-bold shadow-lg shadow-green-100 transition text-sm flex items-center justify-center gap-2">
                                            <span class="material-symbols-outlined">check_circle</span> Aprobar
                                        </button>
                                    </form>
                                    <button onclick="document.getElementById('rejectModal').classList.remove('hidden'); document.getElementById('rejectModal').classList.add('flex');" 
                                            class="border-2 border-red-100 text-red-600 py-4 rounded-2xl hover:bg-red-50 font-bold transition text-sm flex items-center justify-center gap-2">
                                        <span class="material-symbols-outlined">cancel</span> Rechazar
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="p-4 text-center bg-red-50 text-red-700 rounded-2xl text-xs font-bold border border-red-100">
                                    No tienes permisos de aprobación.
                                </div>
                            }
                        }
                        else if (Model.Documento.StatusId == 3)
                        {
                            if (Model.CanAdminFinalize)
                            {
                                <div class="space-y-3">
                                    <div class="p-4 text-center bg-blue-50 text-blue-700 rounded-2xl text-xs font-bold border border-blue-200 flex flex-col gap-1">
                                        <span class="material-symbols-outlined text-xl">workspace_premium</span>
                                        Candidata a Nueva Version
                                    </div>
                                    <div class="grid grid-cols-2 gap-3">
                                        <form method="post" asp-page-handler="FinalizeApprove">
                                            <input type="hidden" name="id" value="@Model.Documento.Id" />
                                            <button class="w-full bg-green-600 text-white py-4 rounded-2xl hover:bg-green-700 font-bold shadow-lg shadow-green-100 transition text-sm flex items-center justify-center gap-2">
                                                <span class="material-symbols-outlined">verified</span> Activar
                                            </button>
                                        </form>
                                        <button onclick="document.getElementById('rejectModal').classList.remove('hidden'); document.getElementById('rejectModal').classList.add('flex');"
                                                class="border-2 border-red-100 text-red-600 py-4 rounded-2xl hover:bg-red-50 font-bold transition text-sm flex items-center justify-center gap-2">
                                            <span class="material-symbols-outlined">cancel</span> Rechazar
                                        </button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="p-4 text-center bg-blue-50 text-blue-700 rounded-2xl text-xs font-bold border border-blue-200 flex flex-col gap-1">
                                    <span class="material-symbols-outlined text-xl">hourglass_empty</span>
                                    Candidata pendiente de aprobacion final
                                </div>
                            }
                        }
                        else if (Model.Documento.StatusId == 5)
                        {
                            <div class="p-4 text-center bg-green-600 text-white rounded-2xl text-sm font-bold shadow-lg shadow-green-100 flex items-center justify-center gap-2 mb-6">
                                <span class="material-symbols-outlined">verified</span> Version Activa
                            </div>
                            
                            <div class="space-y-3 pt-4 border-t border-gray-200">
                                <p class="text-[10px] text-gray-400 uppercase font-bold text-center tracking-widest mb-2">Sincronizacion MongoDB</p>
                                @if (!Model.Documento.SyncFirebase)
                                {
                                    <form method="post" asp-page-handler="SyncFirebase">
                                        <input type="hidden" name="id" value="@Model.Documento.Id" />
                                        <button class="w-full bg-orange-500 text-white py-4 rounded-2xl hover:bg-orange-600 font-bold shadow-xl shadow-orange-100 transition flex items-center justify-center gap-3 text-sm">
                                            <span class="material-symbols-outlined">cloud_upload</span> MongoDB
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <div class="w-full bg-green-50 border border-green-200 text-green-700 py-4 rounded-2xl font-bold text-sm flex items-center justify-center gap-2">
                                        <span class="material-symbols-outlined">check_circle</span> MongoDB Sincronizado
                                    </div>
                                }

                                @if (!Model.Documento.SyncPostgre)
                                {
                                    <form method="post" asp-page-handler="SyncPostgre">
                                        <input type="hidden" name="id" value="@Model.Documento.Id" />
                                        <button class="w-full bg-slate-800 text-white py-4 rounded-2xl hover:bg-slate-700 font-bold shadow-xl shadow-slate-200 transition flex items-center justify-center gap-2 text-sm">
                                            <span class="material-symbols-outlined">database</span> PostgreSQL
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <div class="w-full bg-green-50 border border-green-200 text-green-700 py-4 rounded-2xl font-bold text-sm flex items-center justify-center gap-2">
                                        <span class="material-symbols-outlined">check_circle</span> PostgreSQL Sincronizado
                                    </div>
                                }
                            </div>
                        }
                        else if (Model.Documento.StatusId == 4)
                        {
                            <div class="p-4 text-center bg-red-50 text-red-700 rounded-2xl text-xs font-bold border border-red-200 flex flex-col gap-1">
                                <span class="material-symbols-outlined text-xl">block</span>
                                Documento Rechazado
                            </div>
                        }
                        else if (Model.Documento.StatusId == 6)
                        {
                            <div class="p-4 text-center bg-slate-100 text-slate-700 rounded-2xl text-xs font-bold border border-slate-200 flex flex-col gap-1">
                                <span class="material-symbols-outlined text-xl">history</span>
                                Version Obsoleta
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Documento?.LastErrorLog))
                        {
                            <div class="mt-4 p-4 bg-red-50 border-l-4 border-red-500 rounded-r-xl text-[11px] text-red-800 font-mono overflow-auto max-h-32">
                                <p class="font-bold mb-1 uppercase text-red-600">Log de Error:</p>
                                @Model.Documento.LastErrorLog
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<!-- Historial de Versiones -->
@if (Model.VersionesAnteriores != null && Model.VersionesAnteriores.Any())
{
    <div class="mt-8 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden max-w-7xl mx-auto">
        <div class="bg-gray-50 border-b border-gray-200 px-6 py-4">
            <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-gray-500">source_notes</span>
                Otras versiones del Documento
            </h3>
        </div>
        
        <table class="w-full text-sm text-left">
            <thead class="bg-white text-xs text-gray-600 uppercase font-semibold border-b border-gray-200">
                <tr>
                    <th class="px-6 py-3">Versión</th>
                    <th class="px-6 py-3">Fecha de Creación</th>
                    <th class="px-6 py-3">Estado</th>
                    <th class="px-6 py-3 text-right">Acción</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var v in Model.VersionesAnteriores)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-3 font-medium text-gray-800">v@(QualityDoc.Services.DocumentVersionService.FormatVersion(v.VersionNumber))</td>
                        <td class="px-6 py-3 text-gray-500">@v.CreatedAt.ToString("dd MMM yyyy, HH:mm")</td>
                        <td class="px-6 py-3">
                            <span class="px-2 py-1 rounded text-[10px] uppercase tracking-wider font-bold @(v.StatusId == 5 ? "bg-green-100 text-green-700" : v.StatusId == 6 ? "bg-slate-100 text-slate-700" : "bg-gray-100 text-gray-600")">
                                @(v.Status?.Name ?? "Version")
                            </span>
                        </td>
                        <td class="px-6 py-3 text-right">
                            <a asp-page="/Documents/Approval" asp-route-id="@v.Id" class="text-blue-600 hover:text-blue-800 hover:underline font-medium text-xs">
                                Ver Detalles
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    .hide-unchanged .unchanged-row {
        display: none !important;
    }

    .diff-scroll {
        scrollbar-color: #cbd5e1 #f8fafc;
        scrollbar-width: thin;
    }

    .diff-row.diff-focus {
        animation: diffFocusPulse 1.2s ease-out;
        outline: 2px solid #2563eb;
        outline-offset: -2px;
    }

    @@keyframes diffFocusPulse {
        0% { box-shadow: inset 0 0 0 999px rgba(37, 99, 235, 0.16); }
        100% { box-shadow: inset 0 0 0 999px rgba(37, 99, 235, 0); }
    }
</style>

<script>
    function toggleEditMode() {
        const view = document.getElementById("viewInfo");
        const form = document.getElementById("editForm");
        const btn = document.getElementById("btnToggleEdit");
        
        if (form.classList.contains("hidden")) {
            view.classList.add("hidden");
            form.classList.remove("hidden");
            btn.classList.add("hidden");
        } else {
            view.classList.remove("hidden");
            form.classList.add("hidden");
            btn.classList.remove("hidden");
        }
    }

    function switchTab(tab) {
        const previewTab = document.getElementById("tab-preview");
        const diffTab = document.getElementById("tab-diff");
        const previewContainer = document.getElementById("container-preview");
        const diffContainer = document.getElementById("container-diff");
        const isPreview = tab === 'preview';
        
        if (isPreview) {
            if (previewTab) {
                previewTab.classList.remove("text-gray-500", "border-transparent");
                previewTab.classList.add("text-blue-600", "border-blue-600");
                previewTab.setAttribute("aria-selected", "true");
            }
            if (diffTab) {
                diffTab.classList.remove("text-blue-600", "border-blue-600");
                diffTab.classList.add("text-gray-500", "border-transparent");
                diffTab.setAttribute("aria-selected", "false");
            }
            if (previewContainer) previewContainer.classList.remove("hidden");
            if (diffContainer) diffContainer.classList.add("hidden");
        } else {
            if (diffTab) {
                diffTab.classList.remove("text-gray-500", "border-transparent");
                diffTab.classList.add("text-blue-600", "border-blue-600");
                diffTab.setAttribute("aria-selected", "true");
            }
            if (previewTab) {
                previewTab.classList.remove("text-blue-600", "border-blue-600");
                previewTab.classList.add("text-gray-500", "border-transparent");
                previewTab.setAttribute("aria-selected", "false");
            }
            if (previewContainer) previewContainer.classList.add("hidden");
            if (diffContainer) diffContainer.classList.remove("hidden");
        }
    }
    
    function toggleUnchangedRows() {
        const checkbox = document.getElementById("chkShowOnlyChanges");
        const container = document.getElementById("container-diff");
        if (checkbox && container) {
            if (checkbox.checked) {
                container.classList.add("hide-unchanged");
            } else {
                container.classList.remove("hide-unchanged");
            }
        }
    }

    function scrollToFirstChange() {
        const diffContainer = document.getElementById("container-diff");
        const firstChange = diffContainer?.querySelector('[data-change-row="true"]');

        if (!firstChange) return;

        firstChange.scrollIntoView({ behavior: "smooth", block: "center" });
        firstChange.classList.remove("diff-focus");
        window.setTimeout(() => firstChange.classList.add("diff-focus"), 40);
        window.setTimeout(() => firstChange.classList.remove("diff-focus"), 1400);
    }
</script>

<!-- Historial de Auditoría -->
<div class="mt-8 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden max-w-7xl mx-auto">
    <div class="bg-gray-50 border-b border-gray-200 px-6 py-4">
        <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
            <span class="material-symbols-outlined text-gray-500">history</span>
            Auditoría y Trazabilidad
        </h3>
        <p class="text-xs text-gray-500 mt-1">Historial completo de intervenciones sobre este documento.</p>
    </div>
    
    @if (Model.Historial != null && Model.Historial.Any())
    {
        <div class="p-6">
            <div class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-300 before:to-transparent">
                @foreach (var item in Model.Historial)
                {
                    <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                        <!-- Icon -->
                        <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-slate-300 group-[.is-active]:bg-blue-500 text-white group-[.is-active]:text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 z-10">
                            <span class="material-symbols-outlined text-sm">
                                @(item.Action.Contains("Creado") ? "add_circle" : 
                                  item.Action.Contains("Revisión") ? "visibility" : 
                                  item.Action.Contains("Aprobado") ? "check_circle" : 
                                  "cancel")
                            </span>
                        </div>
                        <!-- Card -->
                        <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-white border border-gray-200 p-4 rounded-xl shadow-sm">
                            <div class="flex items-center justify-between space-x-2 mb-1">
                                <div class="font-bold text-slate-900 text-sm">@item.Action</div>
                                <time class="font-caveat font-medium text-blue-600 text-xs">@item.ActionDate.ToString("dd MMM yyyy, HH:mm")</time>
                            </div>
                            <div class="text-slate-500 text-xs mb-2">Por <span class="font-semibold text-gray-700">@item.User?.FullName</span></div>
                            <div class="text-slate-600 text-xs italic bg-gray-50 p-2 rounded">"@item.Comment"</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="p-8 text-center text-gray-500 text-sm">
            No hay registros de auditoría para este documento.
        </div>
    }
</div>

<!-- Modal de Rechazo -->
<div id="rejectModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-[100] backdrop-blur-sm">
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl p-6 animate-in zoom-in duration-200">
        <h3 class="text-xl font-bold text-gray-800 mb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-red-500">cancel</span>
            Motivo de Rechazo
        </h3>
        <p class="text-sm text-gray-500 mb-4">Por favor, explica detalladamente por qué se rechaza este documento. Este comentario será visible para el autor.</p>
        
        <form method="post" asp-page-handler="Reject">
            <input type="hidden" name="id" value="@Model.Documento?.Id" />
            <textarea name="rejectionComment" rows="4" class="w-full border border-gray-300 rounded-lg p-3 text-sm focus:ring-2 focus:ring-red-500 focus:outline-none resize-none mb-4" placeholder="Ej: Faltan las firmas en la página 3 y el formato no cumple el estándar..." required></textarea>
            
            <div class="flex justify-end gap-3">
                <button type="button" onclick="document.getElementById('rejectModal').classList.add('hidden'); document.getElementById('rejectModal').classList.remove('flex');" class="px-4 py-2 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
                    Cancelar
                </button>
                <button type="submit" class="px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition shadow-sm">
                    Confirmar Rechazo
                </button>
            </div>
        </form>
    </div>
</div>
