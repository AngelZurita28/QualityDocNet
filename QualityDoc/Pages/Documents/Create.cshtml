@page
@model QualityDoc.Pages.Documents.CreateModel

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50">

    <div class="flex items-center justify-center min-h-screen p-6 pb-24">

        <div class="bg-white w-full max-w-3xl rounded-xl shadow-xl p-8">

            <h2 class="text-2xl font-bold mb-6">Subir Documento</h2>

            <form method="post" enctype="multipart/form-data" class="space-y-6">

                <div>
                    <label class="block font-semibold mb-2">Archivo</label>
                    <input type="file" asp-for="File" class="w-full border p-2 rounded" required />
                </div>

                <div>
                    <label class="block font-semibold mb-2">Título</label>
                    <input asp-for="Title" class="w-full border p-2 rounded" required />
                </div>

                <div>
                    <label class="block font-semibold mb-2">Descripción</label>
                    <textarea asp-for="Description" class="w-full border p-2 rounded"></textarea>
                </div>

                <div class="border-t pt-4">

                    <label class="flex items-center gap-2">
                        <input type="checkbox" asp-for="EsNuevaVersion" />
                        Es nueva versión
                    </label>

                    <div class="mt-3">
                        <label class="block text-sm text-gray-600">Código documento existente</label>
                        <input asp-for="CodigoExistente" class="w-full border p-2 rounded" />
                        <small class="text-gray-400">Solo si es nueva versión</small>
                    </div>

                </div>

                <div class="flex justify-end gap-3 pt-4">

                    <a href="/Documents/List"
                           class="px-4 py-2 border rounded text-gray-600 hover:bg-gray-100">
                        Cancelar
                    </a>

                    <button type="submit"
                            class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700">
                        Guardar
                    </button>

                </div>

            </form>

            @if (!string.IsNullOrEmpty(Model.Error))
            {
                <p class="text-red-500 mt-4">@Model.Error</p>
            }

        </div>

    </div>

</body>
</html>