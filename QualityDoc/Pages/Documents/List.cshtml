@page
@model QualityDoc.Pages.Documents.ListModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="p-6 max-w-7xl mx-auto space-y-4 text-sm">

    <div>
        <h2 class="text-xl font-semibold">@Model.PageTitle</h2>
        <p class="text-gray-500 text-xs">@Model.PageDescription</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2 text-sm font-medium">
            <span class="material-symbols-outlined text-[18px]">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center gap-2 text-sm font-medium">
            <span class="material-symbols-outlined text-[18px]">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Panel de Filtros -->
    <div class="bg-white p-4 rounded-lg border shadow-sm flex flex-col md:flex-row gap-4 items-end">
        <form method="get" class="flex-1 flex flex-col md:flex-row gap-4 items-end w-full">
            
            <div class="flex-1">
                <label class="block text-xs font-semibold text-gray-600 mb-1">Buscar Documento</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-2.5 text-gray-400 text-[18px]">search</span>
                    <input type="text" asp-for="SearchTerm" placeholder="Buscar por Título o Código (Ej. DOC-123)..." 
                           class="w-full pl-10 pr-3 py-2 bg-gray-50 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition" />
                </div>
            </div>

            <div class="w-full md:w-48">
                <label class="block text-xs font-semibold text-gray-600 mb-1">Filtrar por Estado</label>
                <select asp-for="StatusFilter" class="w-full px-3 py-2 bg-gray-50 border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
                    @if (Model.StatusOptions.Any(o => o.Id == 1))
                    {
                        <option value="">Todos mis documentos</option>
                    }
                    @foreach (var option in Model.StatusOptions)
                    {
                        <option value="@option.Id">@option.Label</option>
                    }
                </select>
            </div>

            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition shadow-sm h-[38px] flex items-center gap-2">
                Filtrar
            </button>
            
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.StatusFilter.HasValue)
            {
                <a asp-page="./List" class="text-gray-500 hover:text-red-600 text-sm font-medium transition px-2 py-2 h-[38px] flex items-center">
                    Limpiar
                </a>
            }
        </form>
    </div>

    <div class="bg-white rounded-lg border overflow-hidden">

        <table class="w-full text-sm">

            <thead class="bg-gray-50 text-sm text-gray-600">
                <tr>
                    <th class="p-3 text-left">Código</th>
                    <th class="p-3 text-left">Título</th>
                    <th class="p-3 text-center">Versión</th>
                    <th class="p-3 text-center">Estado</th>
                    <th class="p-3 text-left">Autor</th>
                    <th class="p-3 text-left">Empresa</th>
                    <th class="p-3 text-center">Fecha</th>
                    <th class="p-3 text-center">MongoDB</th>
                    <th class="p-3 text-center">Postgre</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var doc in Model.Documentos)
                {
                    <tr class="border-t hover:bg-gray-50 cursor-pointer transition text-xs"
                        onclick="window.location.href='/Documents/Approval?id=@doc.Id'">

                        <td class="p-3 font-medium">@doc.DocumentCode</td>
                        <td class="p-3 font-semibold">
                            @doc.Title
                            @if (doc.IsLatest)
                            {
                                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-blue-100 text-blue-800">
                                    Vigente
                                </span>
                            }
                            else if (doc.StatusId == 6)
                            {
                                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-600">
                                    Histórico
                                </span>
                            }
                            else
                            {
                                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-amber-100 text-amber-700">
                                    En proceso
                                </span>
                            }
                        </td>
                        <td class="p-3 text-center">
                            @(doc.VersionNumber.HasValue ? $"v{QualityDoc.Services.DocumentVersionService.FormatVersion(doc.VersionNumber)}" : "Sin version")
                        </td>
                        <td class="p-3 text-center">
                            @{
                                string badgeClass = doc.StatusId switch {
                                    1 => "bg-gray-100 text-gray-800",
                                    2 => "bg-yellow-100 text-yellow-800",
                                    3 => "bg-blue-100 text-blue-800",
                                    4 => "bg-red-100 text-red-800",
                                    5 => "bg-green-100 text-green-800",
                                    6 => "bg-slate-100 text-slate-700",
                                    _ => "bg-gray-100 text-gray-800"
                                };
                                string statusName = doc.Status?.Name ?? "Borrador";
                            }
                            <span class="px-2 py-1 rounded text-[10px] uppercase tracking-wider font-bold @badgeClass">
                                @statusName
                            </span>
                        </td>
                        <td class="p-3 text-gray-600">@(doc.Author?.FullName ?? "-")</td>
                        <td class="p-3 text-gray-600">@(doc.Company?.Name ?? "-")</td>
                        <td class="p-3 text-center text-gray-500">@doc.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="p-3 text-center">
                            @if (doc.StatusId == 5)
                            {
                                @if (!doc.SyncFirebase)
                                {
                                    <form method="post" asp-page-handler="SyncAsync" class="inline">
                                        <input type="hidden" name="id" value="@doc.Id" />
                                        <button type="submit"
                                                onclick="event.stopPropagation()"
                                                class="relative z-10 bg-blue-600 text-white px-3 py-1 rounded text-[10px] hover:bg-blue-700 transition cursor-pointer">
                                            MongoDB
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-green-600 text-[10px] font-bold">✔ Sincronizado</span>
                                }
                            }
                            else
                            {
                                <span class="text-gray-400 text-[10px] italic">No listo</span>
                            }
                        </td>
                        <td class="p-3 text-center">
                            @if (doc.StatusId == 5)
                            {
                                @if (!doc.SyncPostgre)
                                {
                                    <form method="post" asp-page-handler="SyncPostgre" class="inline">
                                        <input type="hidden" name="id" value="@doc.Id" />
                                        <button type="submit"
                                                onclick="event.stopPropagation()"
                                                class="relative z-10 bg-purple-600 text-white px-3 py-1 rounded text-[10px] hover:bg-purple-700 transition cursor-pointer">
                                            Postgre
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-green-600 text-[10px] font-bold">✔ Sincronizado</span>
                                }
                            }
                            else
                            {
                                <span class="text-gray-400 text-[10px] italic">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="p-3 flex justify-between items-center text-xs">

            <span>Página @Model.PageNumber de @Model.TotalPages</span>

            <div class="flex gap-1">

                <a asp-page="./List"
                       asp-route-pageNumber="@(Model.PageNumber - 1)"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-StatusFilter="@Model.StatusFilter"
                       class="px-2 py-1 border rounded
                    @(Model.PageNumber <= 1 ? "opacity-50 pointer-events-none" : "hover:bg-gray-100")">
                    ◀
                </a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-page="./List"
                           asp-route-pageNumber="@i"
                           asp-route-SearchTerm="@Model.SearchTerm"
                           asp-route-StatusFilter="@Model.StatusFilter"
                           class="px-2 py-1 border rounded
                        @(i == Model.PageNumber ? "bg-blue-600 text-white" : "hover:bg-gray-100")">
                        @i
                    </a>
                }

                <a asp-page="./List"
                       asp-route-pageNumber="@(Model.PageNumber + 1)"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-StatusFilter="@Model.StatusFilter"
                       class="px-2 py-1 border rounded
                    @(Model.PageNumber >= Model.TotalPages ? "opacity-50 pointer-events-none" : "hover:bg-gray-100")">
                    ▶
                </a>

            </div>
        </div>

    </div>

</div>
