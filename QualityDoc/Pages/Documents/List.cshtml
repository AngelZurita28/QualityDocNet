@page
@model QualityDoc.Pages.Documents.ListModel
@{
    ViewData["Title"] = "Mis Documentos";
}

<div class="p-6 max-w-7xl mx-auto space-y-4 text-sm">

    <div>
        <h2 class="text-xl font-semibold">Mis Documentos</h2>
        <p class="text-gray-500 text-xs">Listado general de documentos</p>
    </div>

    <div class="bg-white rounded-lg border overflow-hidden">

        <table class="w-full text-sm">

            <thead class="bg-gray-50 text-sm text-gray-600">
                <tr>
                    <th class="p-3 text-left">Código</th>
                    <th class="p-3 text-left">Título</th>
                    <th class="p-3 text-center">Versión</th>
                    <th class="p-3 text-center">Fecha</th>
                    <th class="p-3 text-center">Sync</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var doc in Model.Documentos)
                {
                    <tr class="border-t hover:bg-gray-50 cursor-pointer transition"
                        onclick="window.location.href='/Documents/Approval?id=@doc.Id'">

                        <td class="p-3 font-medium">
                            @doc.DocumentCode
                        </td>

                        <td class="p-3 max-w-[260px] truncate">
                            @doc.Title
                        </td>

                        <td class="p-3 text-center">
                            <span class="bg-gray-100 px-2 py-1 rounded text-xs">
                                v@doc.VersionNumber
                            </span>
                        </td>

                        <td class="p-3 text-center text-gray-500">
                            @doc.CreatedAt.ToString("dd/MM/yyyy")
                        </td>

                        <td class="p-3 text-center">
                            @if (doc.SyncFirebase)
                            {
                                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">
                                    ✔ Sync
                                </span>
                            }
                            else
                            {
                                <span class="bg-red-100 text-red-600 px-2 py-1 rounded text-xs">
                                    Pendiente
                                </span>
                            }
                        </td>

                    </tr>
                }
            </tbody>
        </table>

        <div class="p-3 flex justify-between items-center text-xs">

            <span>Página @Model.PageNumber de @Model.TotalPages</span>

            <div class="flex gap-1">

                <a asp-page="./List"
                       asp-route-pageNumber="@(Model.PageNumber - 1)"
                       class="px-2 py-1 border rounded
                    @(Model.PageNumber == 1 ? "opacity-50 pointer-events-none" : "hover:bg-gray-100")">
                    ◀
                </a>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-page="./List"
                           asp-route-pageNumber="@i"
                           class="px-2 py-1 border rounded
                        @(i == Model.PageNumber ? "bg-blue-600 text-white" : "hover:bg-gray-100")">
                        @i
                    </a>
                }

                <a asp-page="./List"
                       asp-route-pageNumber="@(Model.PageNumber + 1)"
                       class="px-2 py-1 border rounded
                    @(Model.PageNumber == Model.TotalPages ? "opacity-50 pointer-events-none" : "hover:bg-gray-100")">
                    ▶
                </a>

            </div>
        </div>

    </div>

</div>